# Required (from Feishu App Credentials)
APP_ID=cli_xxx
APP_SECRET=xxx

# Optional for event security; if you set them in Event Subscription, fill here too.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional: route message to your Harness agent HTTP endpoint
# e.g. http://127.0.0.1:8000/api/agent/chat
AGENT_API_URL=
AGENT_API_TIMEOUT_SEC=6

# Optional: local fallback reply prefix when AGENT_API_URL not configured
REPLY_PREFIX=客服助手
