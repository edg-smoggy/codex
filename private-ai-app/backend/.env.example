APP_NAME=Private Multi-Model Gateway
ENV=dev
API_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-string

DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/private_ai
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KIMI_BASE_URL=https://api.moonshot.cn/v1

ALLOW_MOCK_PROVIDER=true
REQUEST_TIMEOUT_SECONDS=90

OPENAI_MODELS=gpt-4o-mini,gpt-4.1-mini
GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-pro
KIMI_MODELS=kimi-k2.5,moonshot-v1-8k,moonshot-v1-32k

DEFAULT_DAILY_TOKEN_LIMIT=250000
DEFAULT_DAILY_COST_LIMIT=20
